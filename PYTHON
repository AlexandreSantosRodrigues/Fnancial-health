# Importações necessárias caso não estejam na memória
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import matplotlib.dates as mdates
from statsmodels.tsa.holtwinters import ExponentialSmoothing
import warnings

warnings.filterwarnings('ignore')

print("⏳ Processando matrizes matemáticas e treinando o modelo Preditivo...")

# ==========================================
# 1. CÁLCULO DE KPIs MATEMÁTICOS
# ==========================================
# Fluxo de Caixa = Σ Entradas - Σ Saídas
liquidez_diaria['Fluxo_Caixa_Diario'] = liquidez_diaria['Entrada'] - liquidez_diaria['Saida']

# Saldo Acumulado (Integral discreta do Fluxo de Caixa no tempo)
# Assumimos saldo inicial zero para fins de demonstração da variação
liquidez_diaria['Saldo_Acumulado'] = liquidez_diaria['Fluxo_Caixa_Diario'].cumsum()

# Índice de Liquidez (Saldo Disponível / Obrigação Média de 7 Dias)
liquidez_diaria['Media_Saidas_7d'] = liquidez_diaria['Saida'].rolling(window=7, min_periods=1).mean()

# Evitando divisão por zero com np.where
liquidez_diaria['Indice_Liquidez'] = np.where(
    liquidez_diaria['Media_Saidas_7d'] == 0, 
    np.nan, 
    liquidez_diaria['Saldo_Acumulado'] / liquidez_diaria['Media_Saidas_7d']
)

# ==========================================
# 2. MODELAGEM PREDITIVA (SÉRIES TEMPORAIS)
# ==========================================
# Preenchendo dias sem transação com 0 (asfreq) para garantir a continuidade do tempo
ts_fluxo = liquidez_diaria['Fluxo_Caixa_Diario'].asfreq('D').fillna(0)

# Suavização Exponencial de Holt-Winters (Captura Nível, Tendência e Sazonalidade)
try:
    # Usamos sazonalidade de 7 dias (padrão semanal de pagamentos)
    modelo = ExponentialSmoothing(ts_fluxo, trend='add', seasonal='add', seasonal_periods=7)
    modelo_treinado = modelo.fit(optimized=True)
    previsao_7d = modelo_treinado.forecast(7)
except Exception as e:
    print("Aviso: Utilizando média preditiva simples devido ao formato da série temporal.")
    ultima_media = ts_fluxo.rolling(7).mean().iloc[-1]
    datas_futuras = pd.date_range(ts_fluxo.index[-1] + pd.Timedelta(days=1), periods=7)
    previsao_7d = pd.Series([ultima_media]*7, index=datas_futuras)

# ==========================================
# 3. DASHBOARD VISUAL (MATPLOTLIB)
# ==========================================
plt.style.use('seaborn-v0_8-darkgrid')
fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(16, 12), gridspec_kw={'height_ratios': [2, 1]})

# --- Gráfico 1: Histórico e Previsão de Caixa ---
# Mostrando os últimos 90 dias para ter contexto visual
ax1.plot(ts_fluxo.index[-90:], ts_fluxo.values[-90:], label='Histórico Real (Últimos 90 Dias)', color='royalblue', linewidth=1.5)
ax1.plot(previsao_7d.index, previsao_7d.values, label='Previsão de Máquina (7 Dias)', color='darkorange', linestyle='--', marker='o', markersize=8)

# Linha do zero (Descasamento) e preenchimentos
ax1.axhline(0, color='red', linestyle='-', linewidth=2, alpha=0.5, label='Linha de Descasamento (R$ 0,00)')
ax1.fill_between(ts_fluxo.index[-90:], 0, ts_fluxo.values[-90:], where=(ts_fluxo.values[-90:] > 0), facecolor='green', alpha=0.1)
ax1.fill_between(ts_fluxo.index[-90:], 0, ts_fluxo.values[-90:], where=(ts_fluxo.values[-90:] < 0), facecolor='red', alpha=0.1)

ax1.set_title('Tesouraria: Dinâmica de Liquidez e Projeção de Curto Prazo', fontsize=16, fontweight='bold')
ax1.set_ylabel('Fluxo de Caixa Diário (R$)', fontsize=12)
ax1.legend(loc='upper left', fontsize=11, framealpha=1)
ax1.xaxis.set_major_formatter(mdates.DateFormatter('%d/%m/%Y'))

# --- Gráfico 2: Índice de Liquidez ---
historico_liquidez = liquidez_diaria['Indice_Liquidez'][-90:]
ax2.plot(historico_liquidez.index, historico_liquidez.values, color='teal', linewidth=2, label='Índice de Liquidez')

# Linhas de referência financeira
ax2.axhline(1.0, color='crimson', linestyle='--', linewidth=2, label='Risco Iminente (< 1.0)')
ax2.axhline(1.5, color='forestgreen', linestyle=':', linewidth=2, label='Zona de Conforto (1.5x)')

ax2.set_title('Termômetro de Capital de Giro', fontsize=14, fontweight='bold')
ax2.set_ylabel('Múltiplo de Cobertura', fontsize=12)
ax2.legend(loc='upper right')
ax2.xaxis.set_major_formatter(mdates.DateFormatter('%d/%m/%Y'))

plt.tight_layout()
plt.show()

# ==========================================
# 4. RELATÓRIO PREDITIVO (TEXTO)
# ==========================================
print("\n" + "="*60)
print("🎯 RELATÓRIO PREDITIVO DA TESOURARIA (PRÓXIMOS 7 DIAS)")
print("="*60)
for data, valor in previsao_7d.items():
    if valor < 0:
        status = "🔴 ALERTA: Descasamento (Necessidade de Capital)"
    else:
        status = "🟢 ESTÁVEL: Superávit Operacional Projetado"
    print(f"Data: {data.strftime('%d/%m/%Y')} | Fluxo Previsto: R$ {valor:,.2f} | Status: {status}")


