import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import matplotlib.dates as mdates
from statsmodels.tsa.holtwinters import ExponentialSmoothing
import warnings

warnings.filterwarnings('ignore')

CAMINHO_KAGGLE = '/kaggle/input/datasets/alexandresanto/financee/Financial Transactions.csv'

# 1. Leitura Inteligente
df = pd.read_csv(CAMINHO_KAGGLE, sep=None, engine='python')
df.columns = df.columns.str.strip()

# 2. Busca Dinâmica da Coluna de Data
possiveis_nomes_data = ['Timestamp', 'timestamp', 'Date', 'date', 'Data', 'data', 'Time', 'time']
coluna_tempo = next((col for col in possiveis_nomes_data if col in df.columns), None)

if coluna_tempo is None:
    raise ValueError(f"❌ Coluna de data não encontrada. Colunas: {df.columns.tolist()}")

print(f"✅ SUCESSO: Coluna '{coluna_tempo}' encontrada. Iniciando conversão temporal...")

# ==========================================
# 3. CONVERSÃO TEMPORAL BLINDADA (A Correção)
# ==========================================
# dayfirst=True: Ensina ao Pandas que "13/01" é 13 de Janeiro, não o mês 13.
# format='mixed': Permite que o Pandas infira o formato linha por linha se houver bagunça no CSV.
# errors='coerce': Se houver uma linha com texto corrompido, transforma em "NaT" (Not a Time) em vez de quebrar o código.
df['Timestamp_Padronizado'] = pd.to_datetime(
    df[coluna_tempo], 
    dayfirst=True, 
    format='mixed', 
    errors='coerce'
)

# Removendo possíveis linhas que não puderam ser convertidas em data
df = df.dropna(subset=['Timestamp_Padronizado'])

# Ordenação e extração da Data Diária
df = df.sort_values('Timestamp_Padronizado')
df['Date'] = df['Timestamp_Padronizado'].dt.date

# ==========================================
# 4. CLASSIFICAÇÃO DE FLUXO FINANCEIRO
# ==========================================
df['TransactionType'] = df['TransactionType'].astype(str).str.strip().str.lower()
inflow_types = ['deposit']
outflow_types = ['withdrawal', 'payment', 'transfer']

df['Fluxo'] = np.where(df['TransactionType'].isin(inflow_types), 'Entrada', 
              np.where(df['TransactionType'].isin(outflow_types), 'Saida', 'Outro'))

# Agregação Diária (Pivot Table)
liquidez_diaria = df.groupby(['Date', 'Fluxo'])['TransactionAmount'].sum().unstack(fill_value=0)

# Verificação de segurança de colunas
for col in ['Entrada', 'Saida']:
    if col not in liquidez_diaria.columns: liquidez_diaria[col] = 0

print("✅ ETL CONCLUÍDO COM SUCESSO. Base pronta e limpa!")
display(liquidez_diaria.head())

