from sklearn.preprocessing import StandardScaler
from sklearn.cluster import KMeans
import seaborn as sns
import matplotlib.pyplot as plt
import pandas as pd
import warnings

warnings.filterwarnings('ignore')

print("⏳ Treinando algoritmo de Clusterização (K-Means) no histórico de saídas...")

# ==========================================
# 1. ENGENHARIA DE FEATURES (Preparando a Matriz de Comportamento)
# ==========================================
# Isolamos apenas as transações onde o dinheiro saiu da empresa
df_saidas = df[df['Fluxo'] == 'Saida'].copy()

# Agrupamos por AccountID (Fornecedor / Centro de Custo)
perfil_contas = df_saidas.groupby('AccountID').agg(
    Frequencia_Saques=('TransactionID', 'count'), # Quantas vezes cobrou?
    Volume_Total_BRL=('TransactionAmount', 'sum')   # CORREÇÃO: Removido o '$'
).reset_index()

# Calculamos o Ticket Médio de cada conta
perfil_contas['Ticket_Medio'] = perfil_contas['Volume_Total_BRL'] / perfil_contas['Frequencia_Saques']

# ==========================================
# 2. NORMALIZAÇÃO MATEMÁTICA
# ==========================================
# O K-Means calcula distâncias euclidianas. Precisamos colocar a Frequência 
# e o Volume na mesma escala para que valores altos em R$ não esmaguem a contagem de frequência.
features = ['Frequencia_Saques', 'Volume_Total_BRL']
scaler = StandardScaler()
X_scaled = scaler.fit_transform(perfil_contas[features])

# ==========================================
# 3. TREINAMENTO DO ALGORITMO K-MEANS
# ==========================================
# Vamos pedir para a IA dividir nossos fornecedores/despesas em 4 grupos (Clusters)
kmeans = KMeans(n_clusters=4, random_state=42, n_init=10)
perfil_contas['Cluster'] = kmeans.fit_predict(X_scaled)

# Mapeando nomes amigáveis para os Clusters com base nos centroides
centroides = perfil_contas.groupby('Cluster')[features].mean()
# Ordenando por volume para identificar o pior cluster
centroides = centroides.sort_values(by='Volume_Total_BRL')

mapa_nomes = {
    centroides.index[0]: '1. Baixo Impacto (Rotina)',
    centroides.index[1]: '2. Ticket Médio Frequente',
    centroides.index[2]: '3. Sugadores de Caixa',
    centroides.index[3]: '4. ALERTA: Predadores de Capital'
}
perfil_contas['Perfil_Financeiro'] = perfil_contas['Cluster'].map(mapa_nomes)

# ==========================================
# 4. VISUALIZAÇÃO DE INTELIGÊNCIA (DASHBOARD)
# ==========================================
plt.figure(figsize=(12, 8))
sns.set_theme(style="whitegrid")

# Gráfico de Dispersão (Scatter Plot)
scatter = sns.scatterplot(
    data=perfil_contas, 
    x='Frequencia_Saques', 
    y='Volume_Total_BRL', 
    hue='Perfil_Financeiro', 
    palette=['#2ca02c', '#1f77b4', '#ff7f0e', '#d62728'], # Cores semânticas
    size='Ticket_Medio', sizes=(50, 400), alpha=0.7, edgecolor='black'
)

plt.title('Mapa de Calor de Despesas: Onde está o Vazamento de Caixa?', fontsize=16, fontweight='bold', pad=20)
plt.xlabel('Frequência de Pagamentos (Qtd de Transações)', fontsize=12)
plt.ylabel('Volume Total Drenado (R$)', fontsize=12)
plt.legend(title='Perfil de Risco (Algoritmo)', bbox_to_anchor=(1.05, 1), loc='upper left')
plt.tight_layout()
plt.show()

# ==========================================
# 5. RELATÓRIO DE AÇÃO DA DIRETORIA
# ==========================================
alvo_critico = perfil_contas[perfil_contas['Perfil_Financeiro'].str.contains('Predadores')]
print("\n" + "="*70)
print("🎯 LISTA DE ALVOS PARA CORTE OU RENEGOCIAÇÃO IMEDIATA (Cluster 4)")
print("="*70)
print("Estas são as contas (AccountIDs) responsáveis pela maior drenagem de capital.")
print("Reduzir o impacto destas contas ajudará a fechar o rombo diário.\n")

# Mostra o Top 5 contas que mais sugam caixa no cluster crítico
display(alvo_critico.sort_values('Volume_Total_BRL', ascending=False).head(5)[['AccountID', 'Frequencia_Saques', 'Ticket_Medio', 'Volume_Total_BRL']])

